<!DOCTYPE html>
<html lang="te">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>శోధన ఫలితాలు - Telugu Movie Images</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">🎬 తెలుగు సినిమా</a>
            <a href="/" class="btn btn-outline-light">← హోమ్‌కు వెళ్లు</a>
        </div>
    </nav>

    <div class="container my-5">
        <h2>శోధన ఫలితాలు: "{{ query }}"</h2>
        <p class="text-muted">{{ movies|length }} సినిమాలు కనుగొనబడ్డాయి</p>
        
        <div class="row">
            {% for movie in movies %}
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="card h-100">
                    {% if movie.poster_url %}
                    <img src="{{ movie.poster_url }}" class="card-img-top" style="height: 250px; object-fit: cover;" alt="{{ movie.title }}">
                    {% else %}
                    <img src="https://via.placeholder.com/300x250?text=No+Image" class="card-img-top" alt="No Image">
                    {% endif %}
                    <div class="card-body">
                        <h5 class="card-title">{{ movie.title }}</h5>
                        <p class="card-text">
                            <small>{{ movie.director }}</small><br>
                            <small class="text-muted">{{ movie.release_year }}</small>
                        </p>
                        <a href="/movie/{{ movie.id }}" class="btn btn-primary btn-sm">వివరాలు చూడండి</a>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12">
                <div class="alert alert-warning">
                    మీ శోధన కోసం ఎటువంటి సినిమాలు కనుగొనబడలేదు.
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
